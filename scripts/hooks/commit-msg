#!/usr/bin/env bash
# Reject commit-message attribution trailers and tool-signature lines.
#
# Install (one-time, per clone/worktree):
#   git config core.hooksPath scripts/hooks
# or copy into .git/hooks/:
#   cp scripts/hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

set -u
msg_file="$1"
[ -r "$msg_file" ] || exit 0

if grep -iqE '(^co-authored-by:|generated[[:space:]]+with[[:space:]]+|/[[:alnum:]_.-]+/code\b|^[[:space:]]*assistant[[:space:]]*<)' "$msg_file"; then
  echo "" >&2
  echo "commit-msg hook: REJECTED - attribution trailer or tool signature detected." >&2
  echo "Policy: keep commit messages free of co-author trailers and generated-by signatures." >&2
  echo "Remove the attribution/signature line and retry." >&2
  echo "" >&2
  echo "Offending line(s):" >&2
  grep -niE '(^co-authored-by:|generated[[:space:]]+with[[:space:]]+|/[[:alnum:]_.-]+/code\b|^[[:space:]]*assistant[[:space:]]*<)' "$msg_file" >&2
  exit 1
fi

exit 0
